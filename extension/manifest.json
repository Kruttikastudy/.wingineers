{
  "manifest_version": 3,
  "name": "PhishGuard — Phishing Link Detector",
  "version": "1.0.0",
  "description": "Detects phishing links in real-time and warns you before visiting dangerous websites.",
  "permissions": [
    "webNavigation",
    "storage",
    "activeTab",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["gmail_content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/shield-16.svg",
      "48": "icons/shield-48.svg",
      "128": "icons/shield-128.svg"
    }
  },
  "icons": {
    "16": "icons/shield-16.svg",
    "48": "icons/shield-48.svg",
    "128": "icons/shield-128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": ["warning.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
